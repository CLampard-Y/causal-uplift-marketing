# Required .gitignore rules

# Raw data artifacts (large files, excluded from version control)
# NOTE: some environments use a global gitignore that ignores `data/` entirely.
# The following negations ensure the repo can still track folder scaffolding docs.
!data/
!data/README.md
!data/raw/
!data/processed/
!data/features/

data/raw/*
!data/raw/.gitkeep

# Processed and feature datasets (reproducible from source code)
data/processed/*
!data/processed/.gitkeep
data/features/*
!data/features/.gitkeep

# Serialized model artifacts
outputs/models/*.pkl
outputs/models/*.joblib

# Python cache and notebook checkpoints
__pycache__/
*.pyc
.ipynb_checkpoints/

# Environment and virtual environment files
.env
venv/
.venv/
